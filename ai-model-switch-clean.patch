+
+.message-row {
+  display: flex;
+  align-items: flex-start;
+  gap: 16rpx;
+  margin-bottom: 24rpx;
+}
+
+.message-row--user {
+  flex-direction: row-reverse;
+}
+
+.avatar {
+  width: 72rpx;
+  height: 72rpx;
+  border-radius: 50%;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  color: #ffffff;
+  font-size: 24rpx;
+  font-weight: 700;
+  flex-shrink: 0;
+}
+
+.avatar--assistant {
+  background: linear-gradient(135deg, #0052d9, #4f7dff);
+}
+
+.avatar--user {
+  background: linear-gradient(135deg, #00a870, #4bc3a7);
+}
+
+.bubble {
+  max-width: calc(100% - 120rpx);
+  padding: 22rpx 24rpx;
+  border-radius: 24rpx;
+  font-size: 28rpx;
+  line-height: 1.7;
+  word-break: break-word;
+  white-space: pre-wrap;
+  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
+}
+
+.bubble--assistant {
+  background: #ffffff;
+  color: #1f2329;
+  border-top-left-radius: 8rpx;
+}
+
+.bubble--user {
+  background: #0052d9;
+  color: #ffffff;
+  border-top-right-radius: 8rpx;
+}
+
+.bubble--error {
+  background: #fff1f0;
+  color: #cf1322;
+}
+
+.bubble-loading {
+  display: inline-flex;
+  align-items: center;
+  gap: 12rpx;
+  margin-top: 12rpx;
+}
+
+.bubble-loading__text {
+  font-size: 24rpx;
+  color: rgba(0, 0, 0, 0.45);
+}
+
+.composer-placeholder {
+  height: calc(220rpx + env(safe-area-inset-bottom));
+  flex-shrink: 0;
+}
+
+.composer {
+  position: fixed;
+  left: 24rpx;
+  right: 24rpx;
+  bottom: 0;
+  padding: 24rpx 24rpx calc(env(safe-area-inset-bottom) + 24rpx);
+  background: rgba(255, 255, 255, 0.96);
+  border-radius: 32rpx 32rpx 0 0;
+  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.06);
+  backdrop-filter: blur(20rpx);
+}
+
+.composer__textarea {
+  width: 100%;
+  min-height: 112rpx;
+  max-height: 280rpx;
+  padding: 20rpx 24rpx;
+  margin-bottom: 20rpx;
+  border-radius: 24rpx;
+  background: #f5f7fb;
+  box-sizing: border-box;
+  font-size: 28rpx;
+  line-height: 1.6;
+}
+
+.composer__placeholder {
+  color: rgba(0, 0, 0, 0.35);
+}
--- a/pages/aiChat/index.wxml
+++ b/pages/aiChat/index.wxml
@@ -0,0 +1,55 @@
+<t-navbar title="AI 穿搭助手" left-arrow />
+
+<view class="ai-chat-page">
+  <view class="toolbar">
+    <picker mode="selector" range="{{ modelOptions }}" range-key="label" value="{{ selectedModelIndex }}" bindchange="handleModelChange">
+      <view class="picker-trigger">
+        <text class="picker-label">当前模型</text>
+        <text class="picker-value">{{ modelOptions[selectedModelIndex].label }}</text>
+      </view>
+    </picker>
+    <t-button size="small" theme="default" variant="outline" bindtap="clearHistory">清空对话</t-button>
+  </view>
+
+  <scroll-view class="message-scroll" scroll-y scroll-into-view="{{ anchorId }}">
+    <view class="message-list">
+      <block wx:for="{{ messages }}" wx:key="id">
+        <view class="message-row {{ item.role === 'user' ? 'message-row--user' : 'message-row--assistant' }}">
+          <view class="avatar {{ item.role === 'user' ? 'avatar--user' : 'avatar--assistant' }}">
+            {{ item.role === 'user' ? '我' : 'AI' }}
+          </view>
+          <view class="bubble {{ item.role === 'user' ? 'bubble--user' : 'bubble--assistant' }} {{ item.error ? 'bubble--error' : '' }}">
+            <text selectable="true" space="ensp">{{ item.content }}</text>
+            <view wx:if="{{ item.loading }}" class="bubble-loading">
+              <t-loading theme="spinner" size="36rpx" />
+              <text class="bubble-loading__text">请稍候…</text>
+            </view>
+          </view>
+        </view>
+      </block>
+      <view id="bottom" />
+    </view>
+  </scroll-view>
+
+  <view class="composer-placeholder" />
+  <view class="composer" style="bottom: {{ keyboardHeight }}px;">
+    <textarea
+      class="composer__textarea"
+      value="{{ inputValue }}"
+      maxlength="-1"
+      auto-height
+      placeholder="问我穿搭问题，例如：春天通勤怎么穿得干净利落？"
+      placeholder-class="composer__placeholder"
+      adjust-position="{{ false }}"
+      hold-keyboard="{{ true }}"
+      cursor-spacing="24"
+      show-confirm-bar="{{ false }}"
+      bindkeyboardheightchange="handleKeyboardHeightChange"
+      bindblur="handleBlur"
+      bindinput="handleInput"
+    />
+    <t-button theme="primary" size="large" loading="{{ loading }}" disabled="{{ !inputValue || loading }}" bindtap="handleSend">
+      发送
+    </t-button>
+  </view>
+</view>
