<wxs src="./index.wxs" module="utils" />

<nav nav-type="title" title-text="全部消息"></nav>
<view class="ai-entry" bindtap="toAIChat">
  <text class="ai-entry__title">AI 穿搭助手</text>
  <text class="ai-entry__desc">支持切换 GLM-4.7-Flash / SiliconFlow Qwen3.5-4B / OpenRouter Free</text>
</view>
<scroll-view
  class="message-list"
  scroll-y
  refresher-enabled
  refresher-triggered="{{ loading }}"
  bindrefresherrefresh="getMessageList"
>
  <t-cell
    wx:for="{{ messageList }}"
    wx:key="index"
    t-class-image="avatar"
    t-class-description="content {{ utils.isRead(item.messages) ? '' : 'unread' }}"
    image="{{ item.avatar }}"
    title="{{ item.name }}"
    description="{{ item.messages[item.messages.length - 1].content }}"
    hover
    bind:tap="toChat"
    data-user-id="{{ item.userId }}"
  >
    <t-badge slot="right-icon" count="{{ utils.computeUnreadNum(item.messages) }}" class="wrapper" />
  </t-cell>
</scroll-view>
